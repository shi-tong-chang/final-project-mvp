# 本機 Codex CLI executable；不得在此檔放入 API key 或登入憑證。
CODEX_GATEWAY_CODEX_BINARY=codex

# 留空時沿用本機 Codex 設定，不猜測 model ID。
# CODEX_GATEWAY_CODEX_MODEL=

CODEX_GATEWAY_THREAD_EPHEMERAL=true
CODEX_GATEWAY_STARTUP_TIMEOUT_SECONDS=15
CODEX_GATEWAY_TURN_TIMEOUT_SECONDS=900
CODEX_GATEWAY_SHUTDOWN_TIMEOUT_SECONDS=5

# 分鏡工作流只允許連到 loopback ComfyUI；不得填 0.0.0.0 或外站。
STORYBOARD_WORKFLOW_COMFYUI_BASE_URL=http://127.0.0.1:8188
STORYBOARD_WORKFLOW_CONNECT_TIMEOUT_SECONDS=5
STORYBOARD_WORKFLOW_REQUEST_TIMEOUT_SECONDS=30
STORYBOARD_WORKFLOW_PROMPT_TIMEOUT_SECONDS=1800
STORYBOARD_WORKFLOW_POLL_INTERVAL_SECONDS=1

# 角色四視圖與場景定稿的跨重啟本機圖庫；與 runtime ownership 隔離。
STORYBOARD_WORKFLOW_ASSET_LIBRARY_ROOT=.local-data/asset-library

# 單一 Gateway process 的安全容量；達上限時回 429，不會無界累積。
STORYBOARD_WORKFLOW_MAX_QUEUE_SIZE=8
STORYBOARD_WORKFLOW_MAX_RUNS=64
STORYBOARD_WORKFLOW_MAX_RETAINED_IMAGE_BYTES=536870912
